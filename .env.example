# Spotlight content API -- powers the /news blog.
#
# The /news section fetches Business Sorted Kent's published posts from the
# Spotlight console's public, key-scoped content API. Both vars are SERVER-ONLY:
# no NEXT_PUBLIC prefix, so Next never ships them to the browser. The fetch runs
# in a Server Component, so the key never reaches the client and there is no CORS.
#
# Set real values in .env.local (local dev) and in the Vercel project settings
# (preview + production). Do not commit real values.

# Base origin of the Spotlight deployment, no trailing slash.
# e.g. https://spotlight.example.com
SPOTLIGHT_API_BASE_URL=

# Per-client read key issued in Spotlight (sent as Authorization: Bearer <key>).
SPOTLIGHT_CONTENT_API_KEY=
